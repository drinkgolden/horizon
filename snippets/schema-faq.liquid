{%- comment -%}
  FAQPage structured data for SEO.
  Renders JSON-LD from accordion blocks on FAQ-style pages.
  Usage: {% render 'schema-faq', sections: content_for_layout %}

  Note: This outputs the schema wrapper. The actual Q&A pairs are
  extracted from accordion_row blocks that have a title and nested
  text content.
{%- endcomment -%}

{%- assign faq_items = '' -%}
{%- assign faq_count = 0 -%}

{%- for block in section.blocks -%}
  {%- if block.type == 'accordion_row' and block.settings.title != blank -%}
    {%- assign question = block.settings.title | strip_html | json -%}
    {%- capture answer -%}
      {%- for child in block.blocks -%}
        {%- if child.settings.text != blank -%}
          {{ child.settings.text | strip_html | strip_newlines }}
        {%- endif -%}
      {%- endfor -%}
    {%- endcapture -%}
    {%- assign answer = answer | strip | json -%}

    {%- if faq_count > 0 -%}
      {%- assign faq_items = faq_items | append: ',' -%}
    {%- endif -%}

    {%- capture item -%}
    {
      "@type": "Question",
      "name": {{ question }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ answer }}
      }
    }
    {%- endcapture -%}

    {%- assign faq_items = faq_items | append: item -%}
    {%- assign faq_count = faq_count | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}

{%- if faq_count > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{{ faq_items }}]
}
</script>
{%- endif -%}
