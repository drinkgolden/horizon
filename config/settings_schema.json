  {
    "name": "t:names.page_layout",
    "settings": [
      {
        "type": "select",
        "id": "page_width",
        "label": "t:settings.page_width",
        "options": [
          {
            "value": "narrow",
            "label": "t:options.narrow"
          },
          {
            "value": "normal",
            "label": "t:options.normal"
          },
          {
            "value": "wide",
            "label": "t:options.wide"
          }
        ],
        "default": "narrow"
      }
    ]
  },
  {
    "name": "Golden Grid",
    "settings": [
      {
        "type": "header",
        "content": "Borders"
      },
      {
        "type": "checkbox",
        "id": "side_columns_enable",
        "label": "Enable borders",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "side_columns_enable_mobile",
        "label": "Show on mobile",
        "default": true,
        "visible_if": "{{ settings.side_columns_enable }}"
      },
      {
        "type": "range",
        "id": "side_columns_width_desktop",
        "label": "Desktop width",
        "min": 0,
        "max": 5,
        "step": 0.1,
        "unit": "rem",
        "default": 1.5,
        "visible_if": "{{ settings.side_columns_enable }}"
      },
      {
        "type": "range",
        "id": "side_columns_width_mobile",
        "label": "Mobile width",
        "min": 0,
        "max": 5,
        "step": 0.1,
        "unit": "rem",
        "default": 1,
        "visible_if": "{{ settings.side_columns_enable }}"
      },
      {
        "type": "color_scheme",
        "id": "side_columns_color_scheme",
        "label": "Color scheme",
        "default": "scheme-1",
        "visible_if": "{{ settings.side_columns_enable }}"
      },
      {
        "type": "header",
        "content": "Grid"
      },
      {
        "type": "checkbox",
        "id": "section_gridlines_enable",
        "label": "Enable grid",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "section_gridlines_vertical",
        "label": "Show vertical gridlines",
        "default": true,
        "visible_if": "{{ settings.section_gridlines_enable }}"
      },
      {
        "type": "checkbox",
        "id": "section_gridlines_horizontal",
        "label": "Show horizontal gridlines",
        "default": true,
        "visible_if": "{{ settings.section_gridlines_enable }}"
      },
      {
        "type": "paragraph",
        "content": "Adds fine 1px dividers above and below each content section, and optional vertical rails inside the global borders.",
        "visible_if": "{{ settings.section_gridlines_enable }}"
      },
      {
        "type": "color",
        "id": "section_gridline_color",
        "label": "Gridline color",
        "default": "#e5e5e5",
        "alpha": true,
        "visible_if": "{{ settings.section_gridlines_enable }}"
      },
      {
        "type": "color",
        "id": "section_gridline_color_dark",
        "label": "Gridline color on dark backgrounds",
        "default": "rgba(255,255,255,0.12)",
        "alpha": true,
        "visible_if": "{{ settings.section_gridlines_enable }}"
      },
      {
        "type": "color",
        "id": "vertical_divider_color",
        "label": "Vertical gridline color",
        "default": "#d9d9d9",
        "visible_if": "{{ settings.section_gridlines_enable }}"
      },
      {
        "type": "header",
        "content": "Floating button"
      },
      {
        "type": "checkbox",
        "id": "enable_bottom_motif_button",
        "label": "Enable floating motif button",
        "default": false
      },
      {
        "type": "select",
        "id": "bottom_motif_button_color_scheme",
        "label": "Color scheme",
        "options": [
          {
            "value": "scheme-1",
            "label": "Scheme 1"
          },
          {
            "value": "scheme-2",
            "label": "Scheme 2"
          },
          {
            "value": "scheme-3",
            "label": "Scheme 3"
          },
          {
            "value": "scheme-4",
            "label": "Scheme 4"
          }
        ],
        "default": "scheme-1",
        "visible_if": "{{ settings.enable_bottom_motif_button }}"
      },
      {
        "type": "range",
        "id": "bottom_motif_button_scroll_percent",
        "label": "Show after scroll (%)",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "%",
        "default": 0,
        "info": "0 uses the default (one viewport height).",
        "visible_if": "{{ settings.enable_bottom_motif_button }}"
      },
      {
        "type": "text",
        "id": "bottom_motif_button_heading",
        "label": "Heading",
        "default": "Explore the collection",
        "visible_if": "{{ settings.enable_bottom_motif_button }}"
      },
      {
        "type": "richtext",
        "id": "bottom_motif_button_copy",
        "label": "Supporting text",
        "default": "<p>Add a short supporting line here.</p>",
        "visible_if": "{{ settings.enable_bottom_motif_button }}"
      },
      {
        "type": "text",
        "id": "bottom_motif_button_label",
        "label": "Primary button label",
        "default": "Explore",
        "visible_if": "{{ settings.enable_bottom_motif_button }}"
      },
      {
        "type": "url",
        "id": "bottom_motif_button_link",
        "label": "Primary button link",
        "visible_if": "{{ settings.enable_bottom_motif_button }}"
      },
      {
        "type": "text",
        "id": "bottom_motif_secondary_button_label",
        "label": "Secondary button label",
        "default": "Learn more",
        "visible_if": "{{ settings.enable_bottom_motif_button }}"
      },
      {
        "type": "url",
        "id": "bottom_motif_secondary_button_link",
        "label": "Secondary button link",
        "visible_if": "{{ settings.enable_bottom_motif_button }}"
      }
    ]
  },
  {
    "name": "t:names.cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "t:settings.cart_type",
        "options": [
          {
            "value": "page",
            "label": "t:options.page"
          },
          {
            "value": "drawer",
            "label": "t:options.drawer"
          }
        ],
        "default": "page"
      },
      {
        "type": "select",
        "id": "product_title_case",
        "label": "t:settings.product_title_case",
        "options": [
          {
            "value": "default",
            "label": "t:options.default"
          },
          {
            "value": "uppercase",
            "label": "t:options.uppercase"
          }
        ],
        "default": "default"
      },
      {
        "type": "select",
        "id": "cart_price_font",
        "label": "t:settings.font_price",
        "options": [
          {
            "value": "body",
            "label": "t:options.body"
          },
          {
            "value": "subheading",
            "label": "t:options.subheading"
          },
          {
            "value": "heading",
            "label": "t:options.heading"
          },
          {
            "value": "accent",
            "label": "t:options.accent"
          }
        ],
        "default": "subheading"
      },
      {
        "type": "checkbox",
        "id": "auto_open_cart_drawer",
        "label": "t:settings.auto_open_cart_drawer",
        "default": false,
        "visible_if": "{{ settings.cart_type == 'drawer' }}"
      },
      {
        "type": "header",
        "content": "t:content.cart_features"
      },
      {
        "type": "checkbox",
        "id": "show_cart_note",
        "label": "t:settings.seller_note",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "cart_note_open_by_default",
        "label": "t:settings.seller_note_open_by_default",
        "default": false,
        "visible_if": "{{ settings.show_cart_note == true }}"
      },
      {
        "type": "checkbox",
        "id": "show_add_discount_code",
        "label": "t:settings.add_discount_code",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_installments",
        "label": "t:settings.installments",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_accelerated_checkout_buttons",
        "label": "t:settings.checkout_buttons",
        "info": "t:info.checkout_buttons",
        "default": true
      },
      {
        "type": "url",
        "id": "empty_cart_button_link",
        "label": "t:settings.empty_cart_button_link",
        "default": "/collections/all"
      },
      {
        "type": "header",
        "content": "t:content.product_media"
      },
      {
        "type": "select",
        "id": "cart_thumbnail_border",
        "label": "t:settings.style",
        "options": [
          {
            "value": "none",
            "label": "t:options.none"
          },
          {
            "value": "solid",
            "label": "t:options.solid"
          }
        ],
        "default": "none"
      },
      {
        "type": "range",
        "id": "cart_thumbnail_border_width",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:settings.border_width",
        "default": 1,
        "visible_if": "{{ settings.cart_thumbnail_border != 'none' }}"
      },
      {
        "type": "range",
        "id": "cart_thumbnail_border_opacity",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "%",
        "label": "t:settings.border_opacity",
        "default": 50,
        "visible_if": "{{ settings.cart_thumbnail_border != 'none' }}"
      },
      {
        "type": "range",
        "id": "cart_thumbnail_border_radius",
        "label": "t:settings.border_radius",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "default": 0
      }
    ]
  },
  {
    "name": "Pages",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_page_header_breadcrumbs",
        "label": "Show page header breadcrumbs by default",
        "default": true
      }
    ]
  }
]
